{
  "name": "koc-market",
  "version": "1.0.26",
  "description": "Koç Market - Satış Sistemi (Electron masaüstü uygulaması)",
  "main": "main.js",
  "author": "Koç Market",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "com.kocmarket.app",
    "productName": "Koç Market",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "build/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "karabulutoglu-sudo",
        "repo": "koc-market",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Koç Market"
    }
  }
}
